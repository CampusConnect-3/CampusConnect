@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Campus Connect</title>

    
    <! -- login css -->
    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />
</head>

<body>
    <div class="login-container">
        <div class="logo-section">
            <img src="@(Url.Content("~/images/campus-connect-logo.png"))" alt="Campus Connect Logo" class="logo-image" loading="lazy" />
            <p class="logo-subtitle">Smart Request for a Smarter Campus</p>
        </div>

        <form id="account" method="post">
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="ModelOnly" class="validation-summary" role="alert"></div>
            }

            <div class="form-group">
                <label asp-for="Input.Email">Email address</label>
                <input asp-for="Input.Email" type="email" autocomplete="username" aria-required="true" placeholder="student@jacksonville.edu" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Input.Password">Password</label>
                <input asp-for="Input.Password" type="password" autocomplete="current-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="remember-forgot">
                <div class="checkbox-wrapper">
                    <input class="form-check-input" type="checkbox" asp-for="Input.RememberMe" id="rememberMe" />
                    <label asp-for="Input.RememberMe" for="rememberMe">Remember me</label>
                </div>
                <a class="forgot-link" asp-page="./ForgotPassword">Forgot password?</a>
            </div>

            <button id="login-submit" type="submit" class="btn-signin">Sign In</button>

            <div class="footer-links">
                <div class="footer-text">
                    © @DateTime.Now.Year Campus Connect
                    <br />
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Register</a>
                    <span style="color: #5a6170;">|</span>
                    <a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend Confirmation</a>
                </div>
            </div>
        </form>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>