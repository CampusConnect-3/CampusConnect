@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const role = document.getElementById("Input_Role");
        const classRow = document.getElementById("classYearRow");
        const deptRow = document.getElementById("departmentRow");

        function updateRoleFields() {
            classRow.style.display = role.value === "Student" ? "grid" : "none";
            deptRow.style.display = role.value === "Staff" ? "grid" : "none";
