                    <input asp-for="Input.Department"
                           class="cc-input"
                           placeholder="Enter your department"
                           autocomplete="organization" />
                    <span asp-validation-for="Input.Department" class="text-danger"></span>
                </div>

                <!-- EMAIL -->
                <div class="cc-row">
                    <label asp-for="Input.Email" class="cc-label">
                        Email Address: <span class="cc-required">*</span>
                    </label>
                    <input asp-for="Input.Email"
                           class="cc-input"
                           placeholder="Enter your email address"
                           autocomplete="email" />
                    <span asp-validation-for="Input.Email"
                          class="text-danger"></span>
                </div>

                <!-- PASSWORD -->
                <div class="cc-row">
