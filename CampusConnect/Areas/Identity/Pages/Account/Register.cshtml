                           autocomplete="given-name" />
                    <span asp-validation-for="Input.FirstName"
                          class="text-danger"></span>
                </div>

                <!-- LAST NAME -->
                <div class="cc-row">
                    <label asp-for="Input.LastName" class="cc-label">
                        Last Name: <span class="cc-required">*</span>
                    </label>
                    <input asp-for="Input.LastName"
                           class="cc-input"
                           placeholder="Enter your last name"
                           autocomplete="family-name" />
                    <span asp-validation-for="Input.LastName"
                          class="text-danger"></span>
                </div>

                <!-- ID NUMBER -->
                <div class="cc-row">
                    <label asp-for="Input.SchoolId" class="cc-label">
