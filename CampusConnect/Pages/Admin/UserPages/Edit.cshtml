@page
@model CampusConnect.Pages.Admin.UserPages.EditModel

@{
    ViewData["Title"] = "Edit User";
}

<h1>Edit User</h1>

<h4>User Profile</h4>
<hr />

<div class="row">
    <div class="col-md-5">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <input type="hidden" asp-for="user.userID" />

            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="user.fName" class="control-label"></label>
                <input asp-for="user.fName" class="form-control" aria-required="true" />
                <span asp-validation-for="user.fName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="user.lName" class="control-label"></label>
                <input asp-for="user.lName" class="form-control" aria-required="true" />
                <span asp-validation-for="user.lName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="user.username" class="control-label"></label>
                <input asp-for="user.username" class="form-control" aria-required="true" />
                <span asp-validation-for="user.username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="user.email" class="control-label"></label>
                <input asp-for="user.email" class="form-control" aria-required="true" />
                <span asp-validation-for="user.email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="user.department" class="control-label"></label>
                <input asp-for="user.department" class="form-control" />
                <span asp-validation-for="user.department" class="text-danger"></span>
            </div>

            <!-- Display-only: status should be controlled by role assignment workflow -->
            <div class="form-group">
                <label class="control-label">Status</label>
                <input class="form-control" value="@Model.user.status" readonly />
                <small class="form-text text-muted">
                    Status is updated automatically when roles are assigned in "Manage Roles".
                </small>
            </div>

            <!-- Password is handled by Identity. Admin may set a new password if needed -->
            <div class="form-group">
                <label asp-for="NewPassword" class="control-label">Set new password (optional)</label>
                <input asp-for="NewPassword" class="form-control" type="password" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}