@page
@model CampusConnect.Pages.Admin.UserPages.DetailsModel

@{
    ViewData["Title"] = "User Details";
}

<h1>User Details</h1>

<hr />

<div class="row">
    <div class="col-md-6">
        <dl class="row">

            <dt class="col-sm-4">
                First Name
            </dt>
            <dd class="col-sm-8">
                @Model.user.fName
            </dd>

            <dt class="col-sm-4">
                Last Name
            </dt>
            <dd class="col-sm-8">
                @Model.user.lName
            </dd>

            <dt class="col-sm-4">
                Username
            </dt>
            <dd class="col-sm-8">
                @Model.user.username
            </dd>

            <dt class="col-sm-4">
                Email
            </dt>
            <dd class="col-sm-8">
                @Model.user.email
            </dd>

            <dt class="col-sm-4">
                Department
            </dt>
            <dd class="col-sm-8">
                @Model.user.department
            </dd>

            <dt class="col-sm-4">
                Status
            </dt>
            <dd class="col-sm-8">
                @Model.user.status
            </dd>

            <dt class="col-sm-4">
                Account Type
            </dt>
            <dd class="col-sm-8">
                @(string.IsNullOrWhiteSpace(Model.user.identityUserId)
                                ? "Legacy local (no Identity account)"
                                : "Identity account")
            </dd>

        </dl>
    </div>
</div>

<div class="mt-3">
    <a asp-page="./Edit" asp-route-id="@Model.user.userID" class="btn btn-primary">
        Edit
    </a>

    <a asp-page="./Index" class="btn btn-secondary">
        Back to List
    </a>
</div>