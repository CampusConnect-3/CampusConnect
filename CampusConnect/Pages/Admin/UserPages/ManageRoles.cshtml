@page
@model CampusConnect.Pages.Admin.UserPages.ManageRolesModel
@{
    ViewData["Title"] = "Manage Roles";
}

<h1>Manage Roles</h1>

@if (Model.IdentityUser == null)
{
    <div class="alert alert-danger">Identity user not found.</div>
    <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
    return;
}

<h4>
    User: @Model.IdentityUser.Email
    @if (Model.AppUser != null)
    {
        <span> — @Model.AppUser.fName @Model.AppUser.lName</span>
    }
    else
    {
        <span class="text-muted"> (no app profile)</span>
    }
</h4>
<hr />

<div class="row">
    <div class="col-md-6">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <!-- IMPORTANT: post back with identityUserId -->
        <form method="post" asp-route-identityUserId="@Model.IdentityUserId">
            <input type="hidden" asp-for="IdentityUserId" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label class="fw-bold">Current Roles:</label>
                @if (Model.CurrentRoles.Any())
                {
                    <ul>
                        @foreach (var role in Model.CurrentRoles)
                        {
                            <li>@role</li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No roles assigned</p>
                }
            </div>

            <div class="form-group mb-3">
                <label class="fw-bold">Assign Roles:</label>
                @foreach (var role in Model.AllRoles)
                {
                    <div class="form-check">
                        <input class="form-check-input"
                               type="checkbox"
                               name="SelectedRoles"
                               value="@role"
                               id="role_@role"
                               @(Model.CurrentRoles.Contains(role) ? "checked" : "") />
                        <label class="form-check-label" for="role_@role">@role</label>
                    </div>
                }
            </div>

            <div class="form-group">
                <input type="submit" value="Update Roles" class="btn btn-primary" />
                <a asp-page="./Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>

        @if (Model.AppUser == null)
        {
            <div class="alert alert-warning mt-3">
                This account exists in ASP.NET Identity but does not have a matching row in the app <b>users</b> table.
                That’s why Student ID may show as N/A on the home page.
            </div>
        }
    </div>
</div>