@page
@model CampusConnect.Pages.RequestAttachmentsPages.CreateModel

@{
    ViewData["Title"] = "Upload Attachment";
}

<h1>Upload Attachment</h1>
<hr />

@if (Model.RequestId == null)
{
    <div class="alert alert-danger">Missing requestId.</div>
    <a asp-page="/RequestPages/Index" class="btn btn-secondary">Back</a>
    return;
}

<div class="row">
    <div class="col-md-6">
        <form method="post" enctype="multipart/form-data" asp-route-requestId="@Model.RequestId">
            <input type="hidden" asp-for="RequestId" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label class="form-label fw-bold">Request ID</label>
                <input class="form-control" value="@Model.RequestId" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="Upload" class="form-label fw-bold">
                    Choose file <span class="text-danger">*</span>
                </label>
                <input asp-for="Upload" type="file" class="form-control" accept=".png,.jpg,.jpeg,.pdf" />
                <span asp-validation-for="Upload" class="text-danger"></span>
                <div class="form-text">Allowed: PNG, JPG, JPEG, PDF. Max: 5MB.</div>
            </div>

            <button type="submit" class="btn btn-primary">Upload</button>
            <a asp-page="/RequestPages/Details" asp-route-id="@Model.RequestId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}