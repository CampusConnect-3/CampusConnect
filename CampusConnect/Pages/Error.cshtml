@page "{statusCode:int?}"
@model CampusConnect.Pages.ErrorModel
@{
    ViewData["Title"] = "Something went wrong";
}

<div class="container py-5">
    <h1 class="text-danger mb-3">Something went wrong</h1>

    @if (Model.StatusCode.HasValue)
    {
        <p class="lead">
            We couldn't complete your request.
            (Error code: <strong>@Model.StatusCode</strong>)
        </p>
    }
    else
    {
        <p class="lead">
            We couldn't complete your request. Please try again.
        </p>
    }

    @if (Model.ShowRequestId)
    {
        <p class="text-muted">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <div class="mt-4">
        <a class="btn btn-primary" asp-page="/Index">Go to Home</a>
        <a class="btn btn-outline-secondary ms-2" asp-page="/Privacy">Privacy</a>
    </div>
</div>