@page
@model CampusConnect.Pages.RequestPages.DetailsModel

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>request</h4>
    <hr />

    @if (Model.request is null)
    {
        <div class="alert alert-warning">
            Request not found.
        </div>
    }
    else
    {
        <dl class="row">
            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.title)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.request!.title)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.description)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.request!.description)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.priority)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.request!.priority)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.createdAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.request!.createdAt)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.closedAt)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.request!.closedAt)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.buildingName)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.request!.buildingName)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.roomNumber)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.request!.roomNumber)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.phoneNumber)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.request!.phoneNumber)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.email)
            </dt>
            <dd class="col-sm-10">
                @Html.DisplayFor(model => model.request!.email)
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.createdBy)
            </dt>
            <dd class="col-sm-10">
                @(Model.request.createdBy?.email ?? "N/A")
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.assignedTo)
            </dt>
            <dd class="col-sm-10">
                @(Model.request.assignedTo?.email ?? "Unassigned")
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.category)
            </dt>
            <dd class="col-sm-10">
                @(Model.request.category?.categoryName ?? "N/A")
            </dd>

            <dt class="col-sm-2">
                @Html.DisplayNameFor(model => model.request!.status)
            </dt>
            <dd class="col-sm-10">
                @(Model.request.status?.statusName ?? "N/A")
            </dd>
        </dl>
    }
</div>

<div>
    @if (Model.request is not null)
    {
        <a asp-page="./Edit" asp-route-id="@Model.request.requestID">Edit</a>
        <span> | </span>
    }
    <a asp-page="./Index">Back to List</a>
</div>