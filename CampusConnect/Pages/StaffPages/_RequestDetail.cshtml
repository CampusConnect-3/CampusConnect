@model CampusConnect.Models.request

<div class="request-detail">
    <div class="row mb-3">
        <div class="col-md-6">
            <h6>Request Information</h6>
            <dl class="row">
                <dt class="col-sm-4">Request ID:</dt>
                <dd class="col-sm-8">@Model.requestID</dd>

                <dt class="col-sm-4">Title:</dt>
                <dd class="col-sm-8">@Model.title</dd>

                <dt class="col-sm-4">Priority:</dt>
                <dd class="col-sm-8">
                    <span class="badge bg-@(Model.priority == "High" ? "danger" : Model.priority == "Medium" ? "warning" : "secondary")">
                        @Model.priority
                    </span>
                </dd>

                <dt class="col-sm-4">Status:</dt>
                <dd class="col-sm-8">@Model.status?.statusName</dd>

                <dt class="col-sm-4">Category:</dt>
                <dd class="col-sm-8">@Model.category?.categoryName</dd>
            </dl>
        </div>

        <div class="col-md-6">
            <h6>Location & Contact</h6>
            <dl class="row">
                <dt class="col-sm-4">Building:</dt>
                <dd class="col-sm-8">@Model.buildingName</dd>

                <dt class="col-sm-4">Room:</dt>
                <dd class="col-sm-8">@Model.roomNumber</dd>

                <dt class="col-sm-4">Email:</dt>
                <dd class="col-sm-8">@Model.email</dd>

                <dt class="col-sm-4">Phone:</dt>
                <dd class="col-sm-8">@Model.phoneNumber</dd>

                <dt class="col-sm-4">Created:</dt>
                <dd class="col-sm-8">@Model.createdAt.ToString("MMM dd, yyyy hh:mm tt")</dd>
            </dl>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-12">
            <h6>Description</h6>
            <p>@Model.description</p>
        </div>
    </div>

    <!-- Attachments Section -->
    <div class="row mb-3">
        <div class="col-12">
            <h6>Attachments (@Model.attachments.Count)</h6>
            @if (Model.attachments.Any())
            {
                <ul class="list-group">
                    @foreach (var attachment in Model.attachments)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <i class="bi bi-paperclip"></i> @attachment.fileName
                                <small class="text-muted">- Uploaded @attachment.uploadedAt.ToString("MMM dd, yyyy")</small>
                            </div>
                            <a href="@attachment.fileUrl" target="_blank" class="btn btn-sm btn-outline-primary">View</a>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted">No attachments</p>
            }

            <form method="post" asp-page-handler="AddAttachment" enctype="multipart/form-data" class="mt-2">
                <input type="hidden" name="requestId" value="@Model.requestID" />
                <div class="input-group">
                    <input type="file" class="form-control" name="file" required />
                    <button type="submit" class="btn btn-primary">Upload</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Comments Section -->
    <div class="row">
        <div class="col-12">
            <h6>Comments (@Model.comments.Count)</h6>
            <div class="comments-list mb-3" style="max-height: 300px; overflow-y: auto;">
                @foreach (var comment in Model.comments.OrderByDescending(c => c.createdAt))
                {
                    <div class="card mb-2">
                        <div class="card-body p-2">
                            <div class="d-flex justify-content-between">
                                <strong>@comment.creator?.fName @comment.creator?.lName</strong>
                                <small class="text-muted">@comment.createdAt.ToString("MMM dd, yyyy hh:mm tt")</small>
                            </div>
                            <p class="mb-0 mt-1">@comment.commentText</p>
                        </div>
                    </div>
                }
            </div>

            <form method="post" asp-page-handler="AddComment">
                <input type="hidden" name="requestId" value="@Model.requestID" />
                <div class="input-group">
                    <textarea class="form-control" name="commentText" rows="2" placeholder="Add a comment..." required></textarea>
                    <button type="submit" class="btn btn-primary">Send</button>
                </div>
            </form>
        </div>
    </div>
</div>